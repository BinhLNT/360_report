# ============================================================================
# Cấu hình LLM (OpenAI-compatible) cho các tính năng AI của hệ thống 360°
# ----------------------------------------------------------------------------
# Copy file này thành ".env" rồi điền API key. KHÔNG commit file .env thật.
# ============================================================================

# API key của bạn (bắt buộc để bật tính năng AI).
OPENAI_API_KEY=

# Model dùng để sinh nội dung. Mặc định gpt-oss-120b.
OPENAI_MODEL=gpt-oss-120b

# (Tuỳ chọn) Endpoint OpenAI-compatible.
# - Để TRỐNG nếu key của bạn dùng thẳng https://api.openai.com/v1
# - gpt-oss-120b là model OPEN-WEIGHT, thường phục vụ qua nhà cung cấp khác:
#     Groq:        https://api.groq.com/openai/v1
#     Together:    https://api.together.xyz/v1
#     OpenRouter:  https://openrouter.ai/api/v1     (model: openai/gpt-oss-120b)
#     Fireworks:   https://api.fireworks.ai/inference/v1
#     Local vLLM:  http://localhost:8000/v1
#     Local Ollama:http://localhost:11434/v1        (model: gpt-oss:120b)
OPENAI_BASE_URL=

# (Tuỳ chọn) Số nhân viên xử lý song song khi tự động điền AI hàng loạt.
AI_MAX_WORKERS=4

# (Tuỳ chọn) Nhiệt độ sinh văn bản (0.0–1.0). Thấp = ổn định, bám số liệu hơn.
AI_TEMPERATURE=0.4

# (Tuỳ chọn) Mức suy luận cho model reasoning như gpt-oss: low | medium | high.
# Để TRỐNG = dùng mặc định theo tác vụ (điền AI=low, hỏi-đáp=medium). Đặt "low" để
# nhanh & rẻ nhất cho cả lô; "high" nếu muốn lập luận sâu hơn (chậm & tốn hơn).
OPENAI_REASONING_EFFORT=
